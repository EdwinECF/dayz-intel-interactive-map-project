    {
      "order": 1,
      "title": "Understand categories",
      "body": "Buildings and areas are associated with loot usages and categories such as residential, industrial, medical, police, hunting, and military.",
      "id": "loot-economy-basics-step-1",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 2,
      "title": "Understand tiers",
      "body": "Some maps divide loot progression into geographic tiers, with higher-value items concentrated farther from typical spawn areas.",
      "id": "loot-economy-basics-step-2",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 3,
      "title": "Recognize dynamic events",
      "body": "Helicopter crashes, convoys, trains, contaminated areas, and other events can provide specialized loot.",
      "id": "loot-economy-basics-step-3",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 4,
      "title": "Expect persistence",
      "body": "Dropped and stored items may remain for a period depending on item and server settings.",
      "id": "loot-economy-basics-step-4",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 5,
      "title": "Do not assume instant respawns",
      "body": "Loot replacement depends on the central economy and server conditions, not simply leaving and returning immediately.",
      "id": "loot-economy-basics-step-5",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 6,
      "title": "Account for community servers",
      "body": "Server owners can significantly alter quantities, locations, persistence, and progression.",
      "id": "loot-economy-basics-step-6",
      "image": null,
      "imageAlt": null,
