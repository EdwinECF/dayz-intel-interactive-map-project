      "order": 2,
      "title": "Use visual cover",
      "body": "Travel behind terrain, hedges, walls, and tree lines instead of crossing skylines and open fields.",
      "id": "stealth-and-noise-step-2",
      "image": null,
      "imageAlt": null,
