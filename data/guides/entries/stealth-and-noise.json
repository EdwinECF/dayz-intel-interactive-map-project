    },
    {
      "order": 5,
      "title": "Close or leave doors intentionally",
      "body": "Doors communicate information. Decide whether you want to conceal your route or create misleading signs.",
      "id": "stealth-and-noise-step-5",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 6,
      "title": "Stop regularly",
      "body": "Standing still and listening often detects threats before visual contact.",
