      "mapLink": null,
      "callout": null
    },
    {
      "order": 4,
      "title": "Plan quiet entries",
      "body": "Approach towns from less predictable directions and avoid the main road when players may be nearby.",
      "id": "stealth-and-noise-step-4",
      "image": null,
      "imageAlt": null,
      "layout": "text",
