      "mapLink": null,
      "callout": null
    },
    {
      "order": 3,
      "title": "Limit inventory noise",
      "body": "Some equipment and actions are easier to hear than others. Pause and listen after entering a new area.",
      "id": "stealth-and-noise-step-3",
      "image": null,
      "imageAlt": null,
