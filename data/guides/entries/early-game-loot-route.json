  "summary": "How to create a purposeful route instead of searching every building randomly.",
  "steps": [
    {
      "order": 1,
      "title": "Define immediate needs",
      "body": "Usually prioritize water, cutting tools, food, bandaging, warmer clothing, and a basic weapon.",
      "id": "early-game-loot-route-step-1",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 2,
      "title": "Target matching buildings",
      "body": "Use residential buildings for general supplies, clinics for medical items, police locations for early weapons, and industrial areas for tools.",
      "id": "early-game-loot-route-step-2",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 3,
      "title": "Avoid over-looted centers",
      "body": "Search the edges of settlements, sheds, greenhouses, hunting structures, and small utility buildings.",
      "id": "early-game-loot-route-step-3",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 4,
      "title": "Finish at an exit point",
      "body": "End the route near the road, trail, or forest line leading to your next destination.",
      "id": "early-game-loot-route-step-4",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 5,
      "title": "Do not backtrack unnecessarily",
      "body": "Repeatedly crossing the same street increases exposure without adding much loot.",
      "id": "early-game-loot-route-step-5",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 6,
      "title": "Adapt to evidence",
      "body": "If every door is open and infected are absent or agitated, consider leaving instead of forcing the route.",
      "id": "early-game-loot-route-step-6",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    }
  ],
  "tips": [
    "A short route with a clear goal is better than clearing an entire large city.",
    "Use map markers for your next two destinations, not ten."
  ],
  "warnings": [
    "Police and military buildings attract players even when the loot is poor."
  ],
