    {
      "order": 2,
      "title": "Eat safe food first",
      "body": "Prioritize food that is ready to eat and in good condition. Be cautious with unknown, rotten, burnt, or contaminated items.",
      "id": "food-and-energy-step-2",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 3,
      "title": "Use natural food sources",
      "body": "Fishing, hunting, gardening, fruit, and mushrooms can support longer trips when town loot is unreliable.",
      "id": "food-and-energy-step-3",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 4,
      "title": "Cook meat thoroughly",
      "body": "Prepare harvested meat with clean hands and cook it before eating. Store raw and cooked food separately.",
      "id": "food-and-energy-step-4",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 5,
      "title": "Match movement to supplies",
      "body": "Sprinting, cold exposure, heavy loads, and recovery increase resource pressure. Slow down when reserves are low.",
      "id": "food-and-energy-step-5",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 6,
      "title": "Carry dense emergency food",
      "body": "Keep one compact food item untouched for unexpected detours, injuries, or bad weather.",
