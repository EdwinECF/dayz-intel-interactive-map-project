  "summary": "A symptom-based workflow for stabilizing a sick survivor without wasting medicine.",
  "steps": [
    {
      "order": 1,
      "title": "Leave immediate danger",
      "body": "Find shelter and avoid combat before diagnosing symptoms.",
      "id": "disease-response-step-1",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 2,
      "title": "Record recent exposure",
      "body": "Consider unsafe water, raw food, bloody hands, cold exposure, dirty bandages, gas, or unknown chemicals.",
      "id": "disease-response-step-2",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 3,
      "title": "Observe symptoms",
      "body": "Note coughing, sneezing, vomiting, pain sounds, blurred vision, fever-like behavior, blood changes, and unusual stamina loss.",
      "id": "disease-response-step-3",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 4,
      "title": "Correct the source",
      "body": "Stop consuming the suspected food or water and address cold, wetness, wounds, or contamination.",
      "id": "disease-response-step-4",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 5,
      "title": "Use targeted medicine",
      "body": "Take medication that matches the likely illness rather than combining everything blindly.",
      "id": "disease-response-step-5",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 6,
      "title": "Consume slowly when nauseated",
      "body": "Use small amounts of food and water to reduce vomiting risk while maintaining recovery.",
      "id": "disease-response-step-6",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 7,
      "title": "Reassess",
      "body": "If symptoms worsen, reconsider the diagnosis and seek safer conditions or additional supplies.",
      "id": "disease-response-step-7",
      "image": null,
      "imageAlt": null,
      "layout": "text",
