    {
      "order": 2,
      "title": "Fight one at a time",
      "body": "Use doors, walls, fences, and narrow entrances to isolate infected.",
      "id": "infected-combat-step-2",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 3,
      "title": "Block and counter",
      "body": "Time defensive movement and melee attacks instead of continuously swinging until stamina is empty.",
      "id": "infected-combat-step-3",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 4,
      "title": "Use firearms only when justified",
      "body": "Gunshots can attract infected and players from far beyond the immediate fight.",
      "id": "infected-combat-step-4",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 5,
      "title": "Break contact",
      "body": "If several infected overwhelm you, enter a building, close doors, climb onto a safe obstacle where permitted, or leave the area.",
      "id": "infected-combat-step-5",
      "image": null,
      "imageAlt": null,
      "layout": "text",
      "relatedItemIds": [],
      "mapLink": null,
      "callout": null
    },
    {
      "order": 6,
      "title": "Loot quickly",
      "body": "Infected may carry useful supplies, but standing in the street to inspect every item creates exposure.",
      "id": "infected-combat-step-6",
